APP_NAME=YAM Backend
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Frontend allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# PostgreSQL DSN
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/yam

# Supabase auth verification for protected endpoints
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here

# Defaults for matching
SEARCH_RADIUS_KM=20
SEARCH_LIMIT=20
